{
  "name": "@flarenetwork/flare-tx-verifier",
  "version": "1.2.0",
  "description": "A CLI tool for verifying Flare C-chain and P-chain transactions.",
  "main": "dist/index.js",
  "files": [
    "/dist"
  ],
  "types": "dist/index.d.ts",
  "bin": "./dist/index.js",
  "homepage": "https://github.com/flare-foundation/flare-tx-verifier",
  "repository": {
    "type": "git",
    "url": "https://github.com/flare-foundation/flare-tx-verifier"
  },
  "scripts": {
    "verify": "npx ts-node ./src/index",
    "build": "rm -rf dist/ && npx tsc -b && sed -i'' -e '1s;^;#!/usr/bin/env node\\n;' ./dist/index.js",
    "lint": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepare": "husky install",
    "ci": "pnpm type-check && pnpm lint && pnpm test:coverage && pnpm build"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@flarenetwork/flare-tx-verifier-lib": "^1.2.0",
    "clipboardy": "^2.3.0",
    "web3-utils": "^4.3.2"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  }
}